<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" 
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="repository-and-branch-report" 
              pageWidth="795" 
              pageHeight="842" 
              columnWidth="755" 
              leftMargin="20" 
              rightMargin="20" 
              topMargin="20" 
              bottomMargin="20">

    <!-- Parameters -->
    <parameter name="logo" class="java.io.InputStream"/>
    <parameter name="GeneratedDate" class="java.lang.String"/>

    <!-- Fields -->
    <field name="projectName" class="java.lang.String"/>
    <field name="branchName" class="java.lang.String"/>
    <field name="commit.committedDate" class="java.time.LocalDateTime"/>
    <field name="merged" class="java.lang.Boolean"/>
    <field name="active" class="java.lang.Boolean"/>
    <field name="conciseSummary" class="java.lang.String"/>

    <!-- Groups -->
    <group name="ProjectGroup">
        <groupExpression><![CDATA[$F{projectName}]]></groupExpression>
        <groupHeader>
            <band height="30">
                <textField>
                    <reportElement x="0" y="5" width="755" height="20"/>
                    <textElement textAlignment="Left" verticalAlignment="Middle">
                        <font size="14" isBold="true"/>
                    </textElement>
                    <textFieldExpression><![CDATA["Project: " + $F{projectName}]]></textFieldExpression>
                </textField>
            </band>
        </groupHeader>
    </group>

    <!-- Title -->
    <title>
        <band height="90">
            <staticText>
                <reportElement x="0" y="10" width="600" height="30"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[Repository and Branch Status Report]]></text>
            </staticText>

            <textField>
                <reportElement x="0" y="40" width="400" height="20"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font size="12"/>
                </textElement>
                <textFieldExpression><![CDATA["Date & Time: " + new java.text.SimpleDateFormat("yyyy-MM-dd HH:mm:ss").format(new java.util.Date())]]></textFieldExpression>
            </textField>

            <image scaleImage="RetainShape">
                <reportElement x="605" y="0" width="150" height="60"/>
                <imageExpression><![CDATA[$P{logo}]]></imageExpression>
            </image>

            <line>
                <reportElement x="0" y="70" width="755" height="1"/>
                <graphicElement>
                    <pen lineWidth="0.5" lineStyle="Solid"/>
                </graphicElement>
            </line>
        </band>
    </title>

    <columnHeader>
        <band height="25">
            <frame>
                <reportElement x="0" y="0" width="755" height="20"/>
                <box>
                    <pen lineWidth="0.25"/>
                </box>

                <!-- Branch Name -->
                <staticText>
                    <reportElement x="0" y="0" width="160" height="20" mode="Opaque" backcolor="#659aff" forecolor="white"/>
                    <box leftPadding="5">
                        <pen lineWidth="0.25"/>
                    </box>
                    <textElement textAlignment="Left" verticalAlignment="Middle">
                        <font isBold="true"/>
                    </textElement>
                    <text><![CDATA[Branch Name]]></text>
                </staticText>

                <!-- Last Commit Date -->
                <staticText>
                    <reportElement x="160" y="0" width="110" height="20" mode="Opaque" backcolor="#659aff" forecolor="white"/>
                    <box leftPadding="5">
                        <pen lineWidth="0.25"/>
                    </box>
                    <textElement textAlignment="Left" verticalAlignment="Middle">
                        <font isBold="true"/>
                    </textElement>
                    <text><![CDATA[Last Commit Date]]></text>
                </staticText>

                <!-- Activity Status -->
                <staticText>
                    <reportElement x="270" y="0" width="100" height="20" mode="Opaque" backcolor="#659aff" forecolor="white"/>
                    <box leftPadding="5">
                        <pen lineWidth="0.25"/>
                    </box>
                    <textElement textAlignment="Left" verticalAlignment="Middle">
                        <font isBold="true"/>
                    </textElement>
                    <text><![CDATA[Activity Status]]></text>
                </staticText>

                <!-- Concise Summary -->
                <staticText>
                    <reportElement x="370" y="0" width="385" height="20" mode="Opaque" backcolor="#659aff" forecolor="white"/>
                    <box leftPadding="5">
                        <pen lineWidth="0.25"/>
                    </box>
                    <textElement textAlignment="Left" verticalAlignment="Middle">
                        <font isBold="true"/>
                    </textElement>
                    <text><![CDATA[Concise Summary]]></text>
                </staticText>
            </frame>
        </band>
    </columnHeader>



    <!-- Detail -->
    <detail>
        <band height="30">
            <frame>
                <reportElement x="0" y="0" width="755" height="30" stretchType="RelativeToTallestObject"/>
                <box>
                    <pen lineWidth="0.25"/>
                </box>

                <textField isStretchWithOverflow="true">
                    <reportElement x="0" y="0" width="160" height="30" stretchType="RelativeToTallestObject"/>
                    <box leftPadding="5">
                        <rightPen lineWidth="0.25"/>
                    </box>
                    <textElement textAlignment="Left" verticalAlignment="Middle"/>
                    <textFieldExpression><![CDATA[$F{branchName}]]></textFieldExpression>
                </textField>

                <textField isStretchWithOverflow="true">
                    <reportElement x="160" y="0" width="110" height="30" stretchType="RelativeToTallestObject"/>
                    <box leftPadding="5">
                        <rightPen lineWidth="0.25"/>
                    </box>
                    <textElement textAlignment="Left" verticalAlignment="Middle"/>
                    <textFieldExpression><![CDATA[$F{commit.committedDate}.toString()]]></textFieldExpression>

                    
                </textField>

                <textField isStretchWithOverflow="true">
                    <reportElement x="270" y="0" width="100" height="30" stretchType="RelativeToTallestObject"/>
                    <box leftPadding="5">
                        <rightPen lineWidth="0.25"/>
                    </box>
                    <textElement textAlignment="Left" verticalAlignment="Middle"/>
                    <textFieldExpression><![CDATA[($F{merged} ? "Merged" : "Unmerged") + " (" + ($F{active} ? "Active" : "Stale") + ")"]]></textFieldExpression>
                </textField>

                <textField isStretchWithOverflow="true">
                    <reportElement x="370" y="0" width="385" height="30" stretchType="RelativeToTallestObject"/>
                    <box leftPadding="5" topPadding="5" bottomPadding="5"/>
                    <textElement textAlignment="Left" verticalAlignment="Top" markup="html"/>
                    <textFieldExpression><![CDATA[$F{conciseSummary}]]></textFieldExpression>
                </textField>
            </frame>
        </band>

        
    </detail>
</jasperReport>
